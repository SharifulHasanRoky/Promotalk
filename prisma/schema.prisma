// Promotalk - GoHighLevel-style CRM
// Multi-tenant data model:
//   Agency  -> SubAccount (a.k.a. Location) -> Users / Contacts / Pipelines / etc.
// Most domain rows carry a `subAccountId` (and indirectly an `agencyId`) so we
// can scope queries cleanly per tenant.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANCY
// ─────────────────────────────────────────────────────────────────────────────

model Agency {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  logoUrl     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  subAccounts SubAccount[]
  users       User[]
}

model SubAccount {
  id        String   @id @default(cuid())
  agencyId  String
  name      String
  slug      String
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency        Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  memberships   Membership[]
  contacts      Contact[]
  pipelines     Pipeline[]
  conversations Conversation[]
  calendars     Calendar[]
  campaigns     Campaign[]
  workflows     Workflow[]
  forms         Form[]
  sites         Site[]
  products      Product[]
  reviews       Review[]
  tags          Tag[]
  customFields  CustomField[]

  @@unique([agencyId, slug])
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS & ACCESS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  AGENCY_OWNER
  AGENCY_ADMIN
  SUBACCOUNT_ADMIN
  SUBACCOUNT_USER
}

model User {
  id           String   @id @default(cuid())
  agencyId     String
  email        String   @unique
  name         String?
  passwordHash String?
  role         UserRole @default(SUBACCOUNT_USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agency      Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  memberships Membership[]
}

// Which sub-accounts a user can access (one user can belong to many locations).
model Membership {
  id           String     @id @default(cuid())
  userId       String
  subAccountId String
  role         UserRole   @default(SUBACCOUNT_USER)
  createdAt    DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subAccount SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, subAccountId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTACTS / CRM
// ─────────────────────────────────────────────────────────────────────────────

model Contact {
  id           String   @id @default(cuid())
  subAccountId String
  firstName    String?
  lastName     String?
  email        String?
  phone        String?
  source       String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subAccount    SubAccount     @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  tags          ContactTag[]
  fieldValues   ContactField[]
  opportunities Opportunity[]
  appointments  Appointment[]
  conversations Conversation[]
  formSubmissions FormSubmission[]

  @@index([subAccountId])
  @@index([subAccountId, email])
}

model Tag {
  id           String       @id @default(cuid())
  subAccountId String
  name         String
  color        String?

  subAccount SubAccount   @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  contacts   ContactTag[]

  @@unique([subAccountId, name])
}

model ContactTag {
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
}

model CustomField {
  id           String          @id @default(cuid())
  subAccountId String
  key          String
  label        String
  type         CustomFieldType @default(TEXT)
  options      Json?

  subAccount SubAccount     @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  values     ContactField[]

  @@unique([subAccountId, key])
}

model ContactField {
  id            String @id @default(cuid())
  contactId     String
  customFieldId String
  value         String

  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([contactId, customFieldId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PIPELINES & OPPORTUNITIES
// ─────────────────────────────────────────────────────────────────────────────

model Pipeline {
  id           String          @id @default(cuid())
  subAccountId String
  name         String
  createdAt    DateTime        @default(now())

  subAccount    SubAccount     @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  stages        PipelineStage[]
  opportunities Opportunity[]
}

model PipelineStage {
  id         String @id @default(cuid())
  pipelineId String
  name       String
  position   Int    @default(0)

  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  ABANDONED
}

model Opportunity {
  id         String            @id @default(cuid())
  pipelineId String
  stageId    String
  contactId  String?
  title      String
  value      Decimal?          @db.Decimal(12, 2)
  status     OpportunityStatus @default(OPEN)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  pipeline Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage    PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  contact  Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([pipelineId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CALENDARS & APPOINTMENTS
// ─────────────────────────────────────────────────────────────────────────────

model Calendar {
  id           String   @id @default(cuid())
  subAccountId String
  name         String
  slug         String
  duration     Int      @default(30) // minutes
  bufferBefore Int      @default(0)
  bufferAfter  Int      @default(0)
  createdAt    DateTime @default(now())

  subAccount   SubAccount    @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([subAccountId, slug])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

model Appointment {
  id         String            @id @default(cuid())
  calendarId String
  contactId  String?
  startsAt   DateTime
  endsAt     DateTime
  status     AppointmentStatus @default(SCHEDULED)
  notes      String?

  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  contact  Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([calendarId, startsAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CONVERSATIONS (unified inbox: SMS / Email / Voice / Webchat)
// ─────────────────────────────────────────────────────────────────────────────

enum Channel {
  SMS
  EMAIL
  VOICE
  WEBCHAT
  FB_MESSENGER
  IG_DM
  WHATSAPP
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model Conversation {
  id           String   @id @default(cuid())
  subAccountId String
  contactId    String?
  channel      Channel
  lastMessageAt DateTime @default(now())
  unreadCount  Int      @default(0)

  subAccount SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  contact    Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  messages   Message[]

  @@index([subAccountId, lastMessageAt])
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  direction      MessageDirection
  channel        Channel
  body           String
  createdAt      DateTime         @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMPAIGNS & WORKFLOWS
// ─────────────────────────────────────────────────────────────────────────────

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
}

model Campaign {
  id           String         @id @default(cuid())
  subAccountId String
  name         String
  channel      Channel
  status       CampaignStatus @default(DRAFT)
  body         String?
  scheduledAt  DateTime?
  createdAt    DateTime       @default(now())

  subAccount SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
}

model Workflow {
  id           String         @id @default(cuid())
  subAccountId String
  name         String
  status       WorkflowStatus @default(DRAFT)
  // The visual builder graph (nodes + edges). Stored as JSON for flexibility.
  definition   Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  subAccount SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// FORMS / SURVEYS
// ─────────────────────────────────────────────────────────────────────────────

model Form {
  id           String   @id @default(cuid())
  subAccountId String
  name         String
  // Field schema as JSON: [{ key, label, type, required }]
  schema       Json
  createdAt    DateTime @default(now())

  subAccount  SubAccount       @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  contactId String?
  data      Json
  createdAt DateTime @default(now())

  form    Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────────────────────────────────────────
// SITES / FUNNELS (placeholder)
// ─────────────────────────────────────────────────────────────────────────────

model Site {
  id           String   @id @default(cuid())
  subAccountId String
  name         String
  domain       String?
  // Page tree / blocks as JSON. A real builder fills this in.
  content      Json?
  publishedAt  DateTime?
  createdAt    DateTime @default(now())

  subAccount SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENTS / PRODUCTS (placeholder for Stripe etc.)
// ─────────────────────────────────────────────────────────────────────────────

model Product {
  id           String   @id @default(cuid())
  subAccountId String
  name         String
  description  String?
  priceCents   Int      @default(0)
  currency     String   @default("USD")
  recurring    Boolean  @default(false)
  createdAt    DateTime @default(now())

  subAccount SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// REPUTATION (reviews collected from customers)
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id           String   @id @default(cuid())
  subAccountId String
  rating       Int      // 1..5
  body         String?
  authorName   String?
  source       String?  // google, facebook, internal
  createdAt    DateTime @default(now())

  subAccount SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
}
