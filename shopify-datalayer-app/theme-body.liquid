{%- comment -%}
  ═══════════════════════════════════════════════════════════════════════
  SHOPIFY DATALAYER PRO - PASTE THIS IN theme.liquid BEFORE </body>
  ═══════════════════════════════════════════════════════════════════════
  Location: Shopify Admin → Online Store → Themes → Edit Code → layout/theme.liquid
  Paste just BEFORE closing </body> tag
  ═══════════════════════════════════════════════════════════════════════
{%- endcomment -%}

{%- comment -%} ═══ PRODUCT PAGE — view_item ═══ {%- endcomment -%}
{% if template contains 'product' %}
<script>
(function(){
  var p = {
    item_id: {{ product.selected_or_first_available_variant.sku | default: product.id | json }},
    item_name: {{ product.title | json }},
    price: {{ product.selected_or_first_available_variant.price | divided_by: 100.0 }},
    item_brand: {{ product.vendor | json }},
    item_category: {{ product.type | json }},
    item_variant: {{ product.selected_or_first_available_variant.title | json }},
    currency: {{ shop.currency | json }},
    quantity: 1
  };
  var eid = 'vi_' + Date.now();
  window.dataLayer.push({ecommerce:null});
  window.dataLayer.push({
    'event': 'view_item',
    'event_id': eid,
    'ecommerce': {currency:p.currency, value:p.price, items:[p]},
    'content_ids': [p.item_id],
    'content_name': p.item_name,
    'content_type': 'product',
    'content_category': p.item_category,
    'contents': [{content_id:p.item_id, content_name:p.item_name, price:p.price, quantity:1}],
    'product_id': p.item_id,
    'product_name': p.item_name,
    'value': p.price,
    'currency': p.currency
  });
  window.dataLayer.push({
    'event': 'view_item_remarketing',
    'google_business_vertical': 'retail',
    'dynx_itemid': [p.item_id],
    'dynx_pagetype': 'offerdetail',
    'dynx_totalvalue': p.price,
    'ecomm_prodid': [p.item_id],
    'ecomm_pagetype': 'product',
    'ecomm_totalvalue': p.price
  });
})();
</script>
{% endif %}



{%- comment -%} ═══ COLLECTION PAGE — view_item_list ═══ {%- endcomment -%}
{% if template contains 'collection' %}
<script>
(function(){
  var items = [
    {% for p in collection.products limit:20 %}
    {item_id:{{ p.variants.first.sku | default: p.id | json }},item_name:{{ p.title | json }},price:{{ p.price | divided_by: 100.0 }},item_brand:{{ p.vendor | json }},item_category:{{ p.type | json }},currency:{{ shop.currency | json }},quantity:1,index:{{ forloop.index0 }}}{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];
  var ids = items.map(function(x){return x.item_id;});
  var tv = items.reduce(function(s,x){return s+x.price;},0);
  window.dataLayer.push({ecommerce:null});
  window.dataLayer.push({
    'event': 'view_item_list',
    'ecommerce': {item_list_name:{{ collection.title | json }}, item_list_id:'{{ collection.handle }}', items:items},
    'content_ids': ids,
    'content_type': 'product',
    'value': tv,
    'currency': {{ shop.currency | json }}
  });
  window.dataLayer.push({
    'event': 'view_item_list_remarketing',
    'google_business_vertical': 'retail',
    'dynx_itemid': ids,
    'dynx_pagetype': 'category',
    'dynx_totalvalue': tv,
    'ecomm_prodid': ids,
    'ecomm_pagetype': 'category',
    'ecomm_totalvalue': tv
  });
})();
</script>
{% endif %}

{%- comment -%} ═══ SEARCH PAGE — search ═══ {%- endcomment -%}
{% if template contains 'search' %}
<script>
(function(){
  var sq = {{ search.terms | json }};
  var items = [
    {% for p in search.results limit:10 %}{% if p.object_type == 'product' %}{item_id:{{ p.variants.first.sku | default: p.id | json }},item_name:{{ p.title | json }},price:{{ p.price | divided_by: 100.0 }}}{% unless forloop.last %},{% endunless %}{% endif %}{% endfor %}
  ];
  var ids = items.map(function(x){return x.item_id;});
  window.dataLayer.push({
    'event': 'search',
    'search_term': sq,
    'search_string': sq,
    'query': sq,
    'content_ids': ids,
    'items_found': {{ search.results_count }}
  });
  window.dataLayer.push({
    'event': 'view_search_results_remarketing',
    'google_business_vertical': 'retail',
    'dynx_pagetype': 'searchresults',
    'dynx_itemid': ids,
    'dynx_totalvalue': 0
  });
})();
</script>
{% endif %}

{%- comment -%} ═══ CART PAGE — view_cart ═══ {%- endcomment -%}
{% if template contains 'cart' %}
<script>
(function(){
  var items = [
    {% for item in cart.items %}{item_id:{{ item.sku | default: item.product_id | json }},item_name:{{ item.product.title | json }},price:{{ item.final_price | divided_by: 100.0 }},item_variant:{{ item.variant.title | json }},item_brand:{{ item.vendor | json }},quantity:{{ item.quantity }}}{% unless forloop.last %},{% endunless %}{% endfor %}
  ];
  window.dataLayer.push({ecommerce:null});
  window.dataLayer.push({
    'event': 'view_cart',
    'ecommerce': {currency:{{ shop.currency | json }}, value:{{ cart.total_price | divided_by: 100.0 }}, items:items}
  });
})();
</script>
{% endif %}

{%- comment -%} ═══ HOME PAGE ═══ {%- endcomment -%}
{% if template == 'index' %}
<script>
window.dataLayer.push({
  'event': 'view_home_page',
  'google_business_vertical': 'retail',
  'dynx_pagetype': 'home',
  'ecomm_pagetype': 'home'
});
</script>
{% endif %}

{%- comment -%} ═══ INTERACTION EVENTS (all pages) ═══ {%- endcomment -%}
<script>
(function(){
  var DL = window.dataLayer;
  var C = {currency: {{ shop.currency | json }}, vertical: 'retail', domain: '.'+location.hostname.split('.').slice(-2).join('.')};

  function ck(n){var m=document.cookie.match(new RegExp('(?:^|; )'+n+'=([^;]*)'));return m?decodeURIComponent(m[1]):'';}
  var eid = ck('_pts_eid');
  if(!eid){eid='eid_'+Date.now()+'_'+Math.random().toString(36).substr(2,9);document.cookie='_pts_eid='+eid+';path=/;max-age=33696000;domain='+C.domain+';SameSite=Lax';}

  var params = new URLSearchParams(location.search);
  if(params.get('fbclid')&&!ck('_fbc')){document.cookie='_fbc=fb.1.'+Date.now()+'.'+params.get('fbclid')+';path=/;max-age=33696000;domain='+C.domain+';SameSite=Lax';}
  if(params.get('gclid')&&!ck('_gcl_aw')){document.cookie='_gcl_aw=GCL.'+Math.floor(Date.now()/1000)+'.'+params.get('gclid')+';path=/;max-age=33696000;domain='+C.domain+';SameSite=Lax';}

  // ADD TO CART
  document.addEventListener('click', function(ev){
    var btn = ev.target.closest('[data-add-to-cart], .product-form__submit, button[name="add"], .add-to-cart, form[action*="/cart/add"] button[type="submit"]');
    if(!btn) return;
    var form = btn.closest('form');
    var nameEl = document.querySelector('.product__title, h1.product-single__title, [data-product-title]');
    var priceEl = document.querySelector('.price__regular .price-item, .product__price, [data-product-price]');
    var item = {
      item_id: (form && form.querySelector('[name="id"]')) ? form.querySelector('[name="id"]').value : '',
      item_name: nameEl ? nameEl.textContent.trim() : '',
      price: priceEl ? parseFloat(priceEl.textContent.replace(/[^0-9.]/g,'')) : 0,
      currency: C.currency,
      quantity: (form && form.querySelector('[name="quantity"]')) ? parseInt(form.querySelector('[name="quantity"]').value) : 1
    };
    var eid2 = 'atc_' + Date.now();
    DL.push({ecommerce:null});
    DL.push({
      'event': 'add_to_cart',
      'event_id': eid2,
      'ecommerce': {currency:item.currency, value:item.price*item.quantity, items:[item]},
      'content_ids': [item.item_id],
      'content_name': item.item_name,
      'content_type': 'product',
      'contents': [{content_id:item.item_id, price:item.price, quantity:item.quantity}],
      'product_id': item.item_id,
      'value': item.price*item.quantity,
      'currency': item.currency
    });
    DL.push({
      'event': 'add_to_cart_remarketing',
      'google_business_vertical': C.vertical,
      'dynx_itemid': [item.item_id],
      'dynx_pagetype': 'conversionintent',
      'dynx_totalvalue': item.price*item.quantity,
      'ecomm_prodid': [item.item_id],
      'ecomm_pagetype': 'cart',
      'ecomm_totalvalue': item.price*item.quantity
    });
  });

  // FORM SUBMIT (Lead)
  document.addEventListener('submit', function(ev){
    var f = ev.target;
    if(!f || f.tagName !== 'FORM') return;
    if(f.action && (f.action.indexOf('/cart') > -1 || f.action.indexOf('/checkout') > -1)) return;
    DL.push({'event':'generate_lead','event_id':'lead_'+Date.now(),'form_id':f.id||''});
  });

  // CLICK TO CALL / EMAIL / CHAT / DIRECTIONS
  document.addEventListener('click', function(ev){
    var a;
    if((a=ev.target.closest('a[href^="tel:"]'))){DL.push({'event':'click_to_call','phone_number':a.href.replace('tel:','')});}
    else if((a=ev.target.closest('a[href^="mailto:"]'))){DL.push({'event':'email_click','email_target':a.href.replace('mailto:','').split('?')[0]});}
    else if((a=ev.target.closest('a[href*="wa.me"],a[href*="whatsapp"],a[href*="m.me"]'))){DL.push({'event':'chat_click','chat_type':a.href.indexOf('wa.me')>-1?'whatsapp':'messenger'});}
    else if((a=ev.target.closest('a[href*="maps.google"],a[href*="google.com/maps"],a[href*="waze.com"]'))){DL.push({'event':'get_directions'});}
  });

  // SCROLL DEPTH
  var sf={};
  window.addEventListener('scroll', function(){
    var pct = Math.round(window.scrollY/(document.body.scrollHeight-window.innerHeight)*100);
    [25,50,75,90].forEach(function(t){if(pct>=t&&!sf[t]){sf[t]=1;DL.push({'event':'scroll_depth','scroll_percentage':t});}});
  });

  // CUSTOMER STATUS (with all IDs for EMQ 10/10)
  DL.push({
    'event':'customer_status',
    'customer_type':document.cookie.match(/_pts_purchased/)?'returning':'new',
    'external_id':eid,
    'fbp':ck('_fbp'),
    'fbc':ck('_fbc'),
    'gclid':ck('_gcl_aw')||params.get('gclid')||'',
    'ttclid':params.get('ttclid')||'',
    'li_fat_id':params.get('li_fat_id')||''
  });

  console.log('[Shopify DataLayer] ✓ Ready');
})();
</script>
