{% comment %}
  Shopify DataLayer Pro — Head Block
  Initializes dataLayer with page meta, user data, and customer info
{% endcomment %}

{% if block.settings.enable_datalayer %}
<script>
window.dataLayer = window.dataLayer || [];
window.dataLayer.push({
  'event': 'page_view',
  'page_type': '{{ template.name | default: "other" }}',
  'page_title': {{ page_title | json }},
  'page_location': {{ canonical_url | default: request.url | json }},
  'page_path': '{{ request.path }}',
  'page_referrer': document.referrer || '',
  'shop_name': {{ shop.name | json }},
  'shop_currency': {{ shop.currency | json }},
  'shop_domain': {{ shop.domain | json }},
  'locale': {{ request.locale.iso_code | json }},
  'user_data': {
    {% if customer %}
    'user_id': '{{ customer.id }}',
    'email': {{ customer.email | json }},
    'phone_number': {{ customer.phone | json }},
    'first_name': {{ customer.first_name | json }},
    'last_name': {{ customer.last_name | json }},
    'city': {{ customer.default_address.city | json }},
    'region': {{ customer.default_address.province | json }},
    'postal_code': {{ customer.default_address.zip | json }},
    'country': {{ customer.default_address.country_code | json }},
    'orders_count': {{ customer.orders_count }},
    'total_spent': '{{ customer.total_spent | money_without_currency }}',
    'customer_type': '{% if customer.orders_count > 0 %}returning{% else %}new{% endif %}',
    {% else %}
    'customer_type': 'visitor',
    {% endif %}
    'logged_in': {% if customer %}true{% else %}false{% endif %}
  }
});
</script>
{% endif %}
