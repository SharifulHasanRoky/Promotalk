{% comment %}
  Purchase DataLayer — place in Shopify Settings > Checkout > Additional Scripts
  OR use this as a Web Pixel extension for Checkout Extensibility
{% endcomment %}

{% if first_time_accessed %}
<script>
window.dataLayer = window.dataLayer || [];

// ═══ PURCHASE EVENT ═══
window.dataLayer.push({ecommerce: null});
window.dataLayer.push({
  'event': 'purchase',
  'event_id': 'pur_{{ order.order_number }}',
  'ecommerce': {
    'transaction_id': '{{ order.order_number }}',
    'value': {{ total_price | divided_by: 100.0 }},
    'tax': {{ tax_price | divided_by: 100.0 }},
    'shipping': {{ shipping_price | divided_by: 100.0 }},
    'currency': '{{ shop.currency }}',
    'coupon': '{{ discount_applications.first.title | default: "" }}',
    'payment_method': '{{ order.transactions.first.gateway | default: "" }}',
    'items': [
      {% for item in order.line_items %}
      {
        'item_id': {{ item.sku | default: item.product_id | json }},
        'item_name': {{ item.title | json }},
        'price': {{ item.final_price | divided_by: 100.0 }},
        'item_brand': {{ item.vendor | json }},
        'item_variant': {{ item.variant.title | json }},
        'quantity': {{ item.quantity }},
        'currency': '{{ shop.currency }}'
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  },
  'user_data': {
    'email': {{ billing_address.email | default: customer.email | json }},
    'phone_number': {{ billing_address.phone | default: customer.phone | json }},
    'first_name': {{ billing_address.first_name | json }},
    'last_name': {{ billing_address.last_name | json }},
    'city': {{ billing_address.city | json }},
    'region': {{ billing_address.province | json }},
    'postal_code': {{ billing_address.zip | json }},
    'country': {{ billing_address.country_code | json }},
    {% if customer %}'user_id': '{{ customer.id }}',{% endif %}
    'customer_type': '{% if customer.orders_count > 1 %}returning{% else %}new{% endif %}'
  },
  // FB/TT/Pin/LI/TW params
  'content_ids': [{% for item in order.line_items %}{{ item.sku | default: item.product_id | json }}{% unless forloop.last %},{% endunless %}{% endfor %}],
  'content_type': 'product',
  'num_items': {{ order.line_items.size }},
  'order_id': '{{ order.order_number }}',
  'contents': [{% for item in order.line_items %}{content_id:{{ item.sku | default: item.product_id | json }},quantity:{{ item.quantity }},price:{{ item.final_price | divided_by: 100.0 }}}{% unless forloop.last %},{% endunless %}{% endfor %}],
  'value': {{ total_price | divided_by: 100.0 }},
  'currency': '{{ shop.currency }}',
  'new_customer': {% if customer.orders_count <= 1 %}true{% else %}false{% endif %}
});

// Google Ads Dynamic Remarketing
window.dataLayer.push({
  'event': 'purchase_remarketing',
  'google_business_vertical': 'retail',
  'dynx_itemid': [{% for item in order.line_items %}{{ item.sku | default: item.product_id | json }}{% unless forloop.last %},{% endunless %}{% endfor %}],
  'dynx_pagetype': 'conversion',
  'dynx_totalvalue': {{ total_price | divided_by: 100.0 }},
  'ecomm_prodid': [{% for item in order.line_items %}{{ item.sku | default: item.product_id | json }}{% unless forloop.last %},{% endunless %}{% endfor %}],
  'ecomm_pagetype': 'purchase',
  'ecomm_totalvalue': {{ total_price | divided_by: 100.0 }},
  'transaction_id': '{{ order.order_number }}'
});

// Mark customer cookie
document.cookie = '_pts_purchased=1;path=/;max-age=31536000;SameSite=Lax';
</script>
{% endif %}
